generator client {
  provider = "prisma-client-js"
  //se genera dentro del codigo fuente (no en node_modules/.prisma) para que
  //el tracer de Vercel incluya el cliente en el bundle de la funcion serverless
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id               String   @id @default(uuid())
  name             String
  country          String
  league           String
  stadium          String
  founded          Int
  coach            String
  shortDescription String
  description      String
  logo             String?
  image            String?
  category         String
  titles           Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([name])
}
